# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5000

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=your_database_password
DB_NAME=sao_erecord

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Encryption Keys
ENCRYPTION_KEY=your-encryption-key-min-32-characters-long
HMAC_SECRET=your-hmac-secret-key-for-signatures

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Instructions for Gmail App Password:
# 1. Go to your Google Account settings
# 2. Enable 2-Step Verification
# 3. Go to Security > 2-Step Verification > App passwords
# 4. Generate a new app password for "Mail"
# 5. Copy the 16-character password and paste it above

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpeg,jpg,png,gif,heic

# Session Configuration
SESSION_SECRET=your-session-secret-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
ADMIN_IP_WHITELIST=127.0.0.1,::1
ENABLE_CSRF_PROTECTION=true
SESSION_TIMEOUT_MINUTES=30

# SMS Configuration (Optional - for future use)
# SMS_API_KEY=your-sms-api-key
# SMS_SENDER_ID=CCCS
